{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ESNext",
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true
  },
  "include": [
    "src/**/*"
  ]
}